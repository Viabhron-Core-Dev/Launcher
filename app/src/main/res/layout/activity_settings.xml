<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:padding="16dp">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Launcher Settings"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <!-- Grid Config Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GRID CONFIGURATION"
        android:textColor="#8E8E93"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- Columns -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">
        
        <TextView
            android:id="@+id/lbl_columns"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Columns: 4"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <SeekBar
            android:id="@+id/seek_columns"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:max="3"
            android:progress="1" /> <!-- Max is 3 (represents 3 to 6: 0=3, 1=4, 2=5, 3=6) -->
    </LinearLayout>

    <!-- Rows -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/lbl_rows"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Rows: 5"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <SeekBar
            android:id="@+id/seek_rows"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:max="4"
            android:progress="1" /> <!-- Max is 4 (represents 4 to 8: 0=4, 1=5, 2=6, 3=7, 4=8) -->
    </LinearLayout>

    <!-- Icon Size Config Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ICON SIZE"
        android:textColor="#8E8E93"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/group_icon_size"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <RadioButton
            android:id="@+id/radio_small"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Small"
            android:textColor="#FFFFFF"
            android:buttonTint="#0A84FF" />

        <RadioButton
            android:id="@+id/radio_medium"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Medium"
            android:textColor="#FFFFFF"
            android:buttonTint="#0A84FF"
            android:checked="true" />

        <RadioButton
            android:id="@+id/radio_large"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Large"
            android:textColor="#FFFFFF"
            android:buttonTint="#0A84FF" />
    </RadioGroup>

    <!-- About Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ABOUT"
        android:textColor="#8E8E93"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1C1C1E"
        android:padding="12dp"
        android:layout_marginBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Template Launcher v1.0"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Built strictly in Kotlin with Android 15 SDK, utilizing Room Database and a highly optimized standalone grid layout."
            android:textColor="#8E8E93"
            android:textSize="13sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_system_logs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="View System Logs"
        android:textAllCaps="false"
        android:backgroundTint="#2C2C2E"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp" />

    <!-- Done Button -->
    <Button
        android:id="@+id/btn_done"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save &amp; Return"
        android:textAllCaps="false"
        android:backgroundTint="#0A84FF"
        android:textColor="#FFFFFF" />

</LinearLayout>
